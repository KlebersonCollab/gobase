# Database configuration
# URL de conexão com o banco de dados PostgreSQL
# Exemplo local (com base no docker-compose): postgres://postgres:postgres@localhost:5432/gobase?sslmode=disable
DATABASE_URL=postgres://postgres:postgres@localhost:5432/gobase?sslmode=disable

# JWT Authentication
# Chave secreta usada para assinar e verificar os tokens JWT. Em produção, use uma string longa e aleatória.
JWT_SECRET=super_secret_key_change_me_in_production

# (Opcional) Tempo de expiração dos tokens JWT em horas. Se não informado, o código pode assumir um padrão (ex: 72 horas).
JWT_EXPIRY_HOURS=24
